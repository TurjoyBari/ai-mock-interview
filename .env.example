# Database (Neon PostgreSQL — use the pooled URL in production, sslmode=require)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Clerk Authentication
# Use pk_live_ / sk_live_ keys for production (pk_test_ works but has limits)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# UploadThing
UPLOADTHING_TOKEN=...
UPLOADTHING_SECRET=...
UPLOADTHING_APP_ID=...

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# App — must match your deployed domain in production (no trailing slash)
# Example: https://ai-mock-interview-rust-one.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
