generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  clerkId           String   @unique
  email             String   @unique
  firstName         String?
  lastName          String?
  imageUrl          String?
  targetRole        String?
  experienceLevel   String?
  preferredStack    String[] @default([])
  targetCompanies   String[] @default([])
  skills            String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  settings      UserSettings?
  resumes       Resume[]
  jobDescriptions JobDescription[]
  interviews    Interview[]
  notes         Note[]
  bookmarks     Bookmark[]
  achievements  Achievement[]
  progress      ProgressSnapshot[]
  coachPlans    CoachPlan[]

  @@index([clerkId])
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String  @default("system")
  language        String  @default("en")
  voiceEnabled    Boolean @default(true)
  voiceId         String  @default("Kore")
  notifications   Boolean @default(true)
  hintsEnabled    Boolean @default(false)
  cameraDefault   Boolean @default(false)
  geminiApiKey    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Resume {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName         String
  fileUrl          String
  fileType         String
  rawText          String?  @db.Text
  skills           String[] @default([])
  projects         Json?
  education        Json?
  experience       Json?
  strengths        String[] @default([])
  weaknesses       String[] @default([])
  atsScore         Float?
  missingSkills    String[] @default([])
  suggestions      String[] @default([])
  analysis         Json?
  /// uploaded | extracting | analyzing | completed | failed
  status           String   @default("uploaded")
  processingError  String?
  isPrimary        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  jobMatches JobMatch[]

  @@index([userId])
  @@index([userId, status])
}

model JobDescription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  company         String?
  rawText         String   @db.Text
  keywords        String[] @default([])
  requiredSkills  String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches JobMatch[]

  @@index([userId])
}

model JobMatch {
  id                String   @id @default(cuid())
  resumeId          String
  resume            Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescriptionId  String
  jobDescription    JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
  matchScore        Float
  missingSkills     String[] @default([])
  keywordAnalysis   Json?
  atsImprovements   String[] @default([])
  suggestions       String[] @default([])
  interviewQuestions String[] @default([])
  createdAt         DateTime @default(now())

  @@index([resumeId])
  @@index([jobDescriptionId])
}

model Interview {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  type            String
  difficulty      String
  company         String?
  customCompany   String?
  jobRole         String?
  experienceLevel String?
  techStack       String[] @default([])
  duration        Int
  questionCount   Int
  language        String   @default("en")
  mode            String   @default("text")
  cameraEnabled   Boolean  @default(false)
  hintsEnabled    Boolean  @default(false)
  status          String   @default("scheduled")
  currentPhase    String   @default("introduction")
  startedAt       DateTime?
  completedAt     DateTime?
  overallScore    Float?
  communicationScore Float?
  technicalScore  Float?
  behavioralScore Float?
  transcript      Json?
  recordingUrl    String?
  metadata        Json?
  isFavorite      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  questions       Question[]
  answers         Answer[]
  feedback        Feedback?
  report          Report?
  codingSessions  CodingSession[]
  messages        InterviewMessage[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model InterviewMessage {
  id          String   @id @default(cuid())
  interviewId String
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  role        String
  content     String   @db.Text
  phase       String?
  createdAt   DateTime @default(now())

  @@index([interviewId])
}

model Question {
  id            String   @id @default(cuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  order         Int
  content       String   @db.Text
  type          String
  topic         String?
  difficulty    String?
  hints         String[] @default([])
  isFollowUp    Boolean  @default(false)
  parentId      String?
  codingProblem Json?
  createdAt     DateTime @default(now())

  answers Answer[]

  @@index([interviewId])
}

model Answer {
  id              String   @id @default(cuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionId      String
  question        Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  content         String   @db.Text
  audioUrl        String?
  duration        Int?
  analysis        Json?
  score           Float?
  isGood          Boolean?
  weakPoints      String[] @default([])
  strongPoints    String[] @default([])
  betterVersion   String?  @db.Text
  industryAnswer  String?  @db.Text
  recruiterView   String?  @db.Text
  coaching          Json?
  createdAt       DateTime @default(now())

  @@index([interviewId])
  @@index([questionId])
}

model Feedback {
  id                  String   @id @default(cuid())
  interviewId         String   @unique
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  overallScore        Float
  communicationScore  Float
  confidenceScore     Float
  grammarScore          Float?
  pronunciationScore    Float?
  fluencyScore          Float?
  vocabularyScore       Float?
  technicalScore        Float
  problemSolvingScore   Float
  behaviorScore         Float
  leadershipScore       Float?
  criticalThinkingScore Float?
  timeManagementScore   Float?
  weakAreas             String[] @default([])
  strongAreas           String[] @default([])
  weakTopics            String[] @default([])
  strongTopics          String[] @default([])
  suggestions           String[] @default([])
  mistakesMade          String[] @default([])
  recommendedStudyTopics String[] @default([])
  recurringPatterns     String[] @default([])
  questionsAnsweredWell Json?
  questionsAnsweredPoorly Json?
  improvementRoadmap    Json?
  detailedExplanation   String   @db.Text
  confidenceGraph       Json?
  createdAt             DateTime @default(now())
}

model Report {
  id          String   @id @default(cuid())
  interviewId String   @unique
  interview   Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  title       String
  content     Json
  pdfUrl      String?
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
}

model CodingSession {
  id            String   @id @default(cuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  language      String
  code          String   @db.Text
  problemStatement String @db.Text
  constraints   String?  @db.Text
  sampleInput   String?
  sampleOutput  String?
  testCases     Json?
  passedTests   Int      @default(0)
  totalTests    Int      @default(0)
  timeSpent     Int?
  evaluation    Json?
  complexity    Json?
  alternatives  Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([interviewId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Bookmark {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String
  resourceId String
  title      String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([userId, type, resourceId])
  @@index([userId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  description String
  icon        String?
  unlockedAt  DateTime @default(now())

  @@index([userId])
}

model ProgressSnapshot {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                  DateTime @default(now())
  interviewCount        Int      @default(0)
  questionsSolved       Int      @default(0)
  codingProblemsSolved  Int      @default(0)
  avgCommunicationScore Float?
  avgTechnicalScore     Float?
  avgBehavioralScore    Float?
  practiceStreak        Int      @default(0)
  weakTopics            String[] @default([])
  strongTopics          String[] @default([])

  @@index([userId, date])
}

model CoachPlan {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  topics      String[] @default([])
  projects    String[] @default([])
  codingProblems String[] @default([])
  behavioral  String[] @default([])
  resumeTips  String[] @default([])
  companyRoadmap Json?
  fullPlan    Json
  createdAt   DateTime @default(now())

  @@index([userId])
}
