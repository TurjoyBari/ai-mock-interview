{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push && next build",
  "installCommand": "npm install",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/resume/process/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/resume/extract/route.ts": {
      "maxDuration": 60
    }
  }
}
